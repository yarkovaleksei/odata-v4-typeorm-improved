  "repository": {
    "type": "git",
    "url": "git+https://github.com/yarkovaleksei/odata-v4-typeorm.git"
  },
  "keywords": [
    "typeorm",
    "odata",
    "nodejs",
    "express",
    "nestjs",
    "V4",
    "sql",
    "node"
  ],
  "author": "yarkovaleksei",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yarkovaleksei/odata-v4-typeorm/issues"
  },
  "homepage": "https://github.com/yarkovaleksei/odata-v4-typeorm#readme",
  "dependencies": {
    "odata-v4-parser": "^0.1.29",
    "odata-v4-sql": "^0.1.2"
  },
  "devDependencies": {
    "@types/config": "^0.0.38",
    "@types/express": "^5.0.6",
    "@types/jest": "^26.0.23",
    "@types/node": "^15.12.4",
    "@types/pg": "^8.6.0",
    "config": "^1.21.0",
    "install-peers-cli": "^2.2.0",
    "jest": "^27.0.5",
    "odata-v4-server": "0.2.13",
    "pg": "^6.1.0",
    "ts-jest": "^27.0.3",
    "typescript": "^4.3.4"
  },
  "peerDependencies": {
    "typeorm": "^0.3.28"
  }
