{
  "name": "odata-v4-typeorm-improved",
  "version": "0.2.1",
  "description": "OData to TYPEORM query compiler",
  "main": "build/lib/index.js",
  "typings": "build/lib/index",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "postinstall": "install-peers",
    "build": "tsc",
    "pretest": "yarn build",
    "test": "jest",
    "pretdd": "yarn build",
