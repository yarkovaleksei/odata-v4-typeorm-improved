{
  "name": "odata-v4-typeorm-improved",
  "version": "1.0.0-alpha.2",
  "description": "OData to TYPEORM query compiler",
  "main": "build/src/lib/index.js",
  "typings": "build/src/lib/index",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "rm -rf ./build && tsc --project tsconfig.build.json && rm -rf ./build/src/test",
    "pretest": "yarn build",
    "test": "jest",
    "pretdd": "yarn build",
    "release": "yarn build && npm publish",
    "release:beta": "yarn build && npm publish --tag beta",
    "server": "cd ./examples/server && yarn && yarn start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yarkovaleksei/odata-v4-typeorm.git"
  },
  "keywords": [
    "typeorm",
    "odata",
    "nodejs",
    "express",
    "nestjs",
    "V4",
    "sql",
    "node"
  ],
  "author": "yarkovaleksei",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yarkovaleksei/odata-v4-typeorm/issues"
  },
  "homepage": "https://github.com/yarkovaleksei/odata-v4-typeorm#readme",
  "dependencies": {
    "odata-v4-parser": "^0.1.29",
    "odata-v4-sql": "^0.1.2"
  },
  "devDependencies": {
    "@types/config": "^4.4.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "config": "^4.4.1",
    "install-peers-cli": "^2.2.0",
    "jest": "^30.3.0",
    "odata-v4-server": "0.2.13",
    "pg": "^8.20.0",
    "sqlite3": "^6.0.1",
    "ts-jest": "^29.4.6",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typeorm": "^0.3.28"
  }
}